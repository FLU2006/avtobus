<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           elementFormDefault="qualified"
           targetNamespace="urn:EEC:M:TR:ComplexDataObjects:v1.0.3"
           xmlns:trcdo="urn:EEC:M:TR:ComplexDataObjects:v1.0.3"
           xmlns:ccdo="urn:EEC:M:ComplexDataObjects:v0.4.5"
           xmlns:csdo="urn:EEC:M:SimpleDataObjects:v0.4.5"
           xmlns:trsdo="urn:EEC:M:TR:SimpleDataObjects:v1.0.3"
           version="1.0.3">

    <xs:import namespace="urn:EEC:M:ComplexDataObjects:v0.4.5" schemaLocation="EEC_M_ComplexDataObjects_v0.4.5.xsd"/>
    <xs:import namespace="urn:EEC:M:SimpleDataObjects:v0.4.5" schemaLocation="EEC_M_SimpleDataObjects_v0.4.5.xsd"/>
    <xs:import namespace="urn:EEC:M:TR:SimpleDataObjects:v1.0.3" schemaLocation="EEC_M_TR_SimpleDataObjects_v1.0.3.xsd"/>

    <!-- M.TR.CDE.00025: Область аккредитации (Область аккредитации. Детали) -->
    <xs:element name="AccreditationAreaDetails" type="trcdo:AccreditationAreaDetailsType">
        <xs:annotation>
            <xs:documentation>информация об области аккредитации органа по оценке соответствия</xs:documentation>
        </xs:annotation>
    </xs:element>
    <!-- M.TR.CDT.00017: Область аккредитации (Область аккредитации_ Детали. Тип) -->
    <xs:complexType name="AccreditationAreaDetailsType">
        <xs:annotation>
            <xs:documentation>Компоненты, представляющие информацию об области аккредитации</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element ref="trsdo:SingleListProductIndicator"/>
            <xs:element ref="trsdo:TechnicalRegulationId" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>Номер технического регламента Евразийского экономического союза (технического регламента Таможенного союза)</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="trcdo:CommodityCodeDetails" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element ref="trsdo:ProductName" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>Словесное обозначение продукции, включенной в область аккредитации органа по оценке соответствия</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="trsdo:TestingMethodName" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element ref="trsdo:ControlledIndicatorName" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element ref="trcdo:ControlledIndicatorRegulatingDocDetails" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>Информация о нормативном правовом акте и (или) техническом нормативном правовом акте, нормативном документе, регламентирующем контролируемые показатели и методы контроля</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="trsdo:AccreditationAreaText" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>
    <!-- M.TR.CDE.00015: Сведения об аккредитации (Сведения об аккредитации. Детали) -->
    <xs:element name="AccreditationCertificateDetails" type="trcdo:AccreditationCertificateDetailsType">
        <xs:annotation>
            <xs:documentation>информация об аккредитации органа по оценке соответствия</xs:documentation>
        </xs:annotation>
    </xs:element>
    <!-- M.TR.CDT.00004: Аттестат аккредитации (Аттестат аккредитации_ Детали. Тип) -->
    <xs:complexType name="AccreditationCertificateDetailsType">
        <xs:annotation>
            <xs:documentation>сведения о статусе действия документа</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element ref="csdo:DocId">
                <xs:annotation>
                    <xs:documentation>цифровое или буквенно-цифровое обозначение, присваиваемое документу при его регистрации</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:DocStartDate">
                <xs:annotation>
                    <xs:documentation>Дата начала срока действия документа</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:DocValidityDate" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Дата истечения срока действия документа</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="trsdo:ReissuingReasonName" minOccurs="0"/>
            <xs:element ref="trcdo:DocStatusDetails"/>
        </xs:sequence>
    </xs:complexType>
    <!-- M.TR.CDE.00003: Заявитель (Заявитель. Детали) -->
    <xs:element name="ApplicantDetails" type="trcdo:ApplicantDetailsType">
        <xs:annotation>
            <xs:documentation>Информация о заявителе оценки соответствия продукции</xs:documentation>
        </xs:annotation>
    </xs:element>
    <!-- M.TR.CDT.00014: Заявитель (Заявитель_ Детали. Тип) -->
    <xs:complexType name="ApplicantDetailsType">
        <xs:annotation>
            <xs:documentation>Компоненты, представляющие детализированную информацию о заявителе</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element ref="csdo:UnifiedCountryCode" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>кодовое обозначение страны регистрации хозяйствующего субъекта</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:BusinessEntityName">
                <xs:annotation>
                    <xs:documentation>полное наименование хозяйствующего субъекта или фамилия, имя, отчество физического лица, ведущего хозяйственную деятельность</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:BusinessEntityBriefName" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>сокращенное наименование хозяйствующего субъекта или фамилия, имя, отчество физического лица, ведущего хозяйственную деятельность</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:BusinessEntityTypeCode" minOccurs="0"/>
            <xs:element ref="csdo:BusinessEntityTypeName" minOccurs="0"/>
            <xs:element ref="csdo:BusinessEntityId" minOccurs="0"/>
            <xs:element ref="ccdo:SubjectAddressDetails" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>адрес хозяйствующего субъекта</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="ccdo:CommunicationDetails" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>контактный реквизит хозяйствующего субъекта</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="trcdo:BranchDetails" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>филиал хозяйствующего субъекта</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="trcdo:DeclaringOfficerDetails" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>
    <!-- M.TR.CDE.01003: Заявитель для 225 (Заявитель для 225. Детали) -->
    <xs:element name="ApplicantV1Details" type="trcdo:BusinessEntityV1DetailsType">
        <xs:annotation>
            <xs:documentation>Информация о заявителе оценки соответствия продукции</xs:documentation>
        </xs:annotation>
    </xs:element>
    <!-- M.TR.CDE.00100: Cборочный завод (Cборочный завод. Детали) -->
    <xs:element name="AssemblyFacilityDetails" type="trcdo:BusinessEntityV2DetailsType">
        <xs:annotation>
            <xs:documentation>Информация об организации, осуществляющей сборочное производство продукции организации-изготовителя и уполномоченной этой организацией-изготовителем на оформление электронных паспортов на собранную ею продукцию</xs:documentation>
        </xs:annotation>
    </xs:element>
    <!-- M.TR.CDE.00048: Базовое транспортное средство (Базовое транспортное средство. Детали) -->
    <xs:element name="BaseVehicleDetails" type="trcdo:BaseVehicleDetailsType">
        <xs:annotation>
            <xs:documentation>Информация о транспортном средстве (шасси транспортного средства) другого изготовителя, использованном при изготовлении в качестве базового</xs:documentation>
        </xs:annotation>
    </xs:element>
    <!-- M.TR.CDT.00034: Базовое транспортное средство (Базовое транспортное средство_ Детали. Тип) -->
    <xs:complexType name="BaseVehicleDetailsType">
        <xs:annotation>
            <xs:documentation>Компоненты, представляющие информацию о базовом транспортном средстве</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element ref="csdo:VehicleMakeName" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Наименование марки транспортного средства (шасси транспортного средства, самоходной машины и других видов техники)</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="trsdo:VehicleTypeId">
                <xs:annotation>
                    <xs:documentation>Обозначение типа транспортного средства (шасси транспортного средства, самоходной машины и других видов техники), присвоенное организацией-изготовителем</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:VehicleCommercialName" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Коммерческое наименование транспортного средства (шасси транспортного средства, самоходной машины и других видов техники), присвоенное организацией-изготовителем</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:DocId">
                <xs:annotation>
                    <xs:documentation>Номер паспорта (электронного паспорта) транспортного средства (шасси транспортного средства, самоходной машины и других видов техники)</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:DocCreationDate" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Дата оформления паспорта (электронного паспорта) транспортного средства</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <!-- M.TR.CDE.00078: Филиал (Филиал. Детали) -->
    <xs:element name="BranchDetails" type="ccdo:BusinessEntityDetailsType">
        <xs:annotation>
            <xs:documentation>информация об области аккредитации органа по оценке соответствия</xs:documentation>
        </xs:annotation>
    </xs:element>
    <!-- M.TR.CDT.00022: Хозяйствующий субъект (Хозяйствующий субъект_ Детали: вариант 1. Тип) -->
    <xs:complexType name="BusinessEntityV1DetailsType">
        <xs:annotation>
            <xs:documentation>Компоненты, представляющие детализированную информацию о хозяйствующем субъекте</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element ref="csdo:UnifiedCountryCode">
                <xs:annotation>
                    <xs:documentation>Кодовое обозначение страны регистрации хозяйствующего субъекта</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:BusinessEntityName">
                <xs:annotation>
                    <xs:documentation>Полное наименование хозяйствующего субъекта или фамилия, имя и отчество физического лица, ведущего хозяйственную деятельность</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:BusinessEntityBriefName" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Сокращенное наименование хозяйствующего субъекта или фамилия, имя и отчество физического лица, ведущего хозяйственную деятельность</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:BusinessEntityTypeName" minOccurs="0"/>
            <xs:element ref="csdo:BusinessEntityId" minOccurs="0"/>
            <xs:element ref="ccdo:SubjectAddressDetails" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>Адрес хозяйствующего субъекта</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="ccdo:CommunicationDetails" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>Контактный реквизит хозяйствующего субъекта</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <!-- M.TR.CDT.00064: Хозяйствующий субъект (Хозяйствующий субъект_ Детали: вариант 2. Тип) -->
    <xs:complexType name="BusinessEntityV2DetailsType">
        <xs:annotation>
            <xs:documentation>Компоненты, представляющие детализированную информацию о хозяйствующем субъекте</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element ref="csdo:UnifiedCountryCode">
                <xs:annotation>
                    <xs:documentation>Кодовое обозначение страны регистрации хозяйствующего субъекта</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:BusinessEntityName">
                <xs:annotation>
                    <xs:documentation>Полное наименование хозяйствующего субъекта или фамилия, имя и отчество физического лица, ведущего хозяйственную деятельность</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:BusinessEntityBriefName" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Сокращенное наименование хозяйствующего субъекта или фамилия, имя и отчество физического лица, ведущего хозяйственную деятельность</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:BusinessEntityTypeCode" minOccurs="0"/>
            <xs:element ref="csdo:BusinessEntityTypeName" minOccurs="0"/>
            <xs:element ref="csdo:BusinessEntityId" minOccurs="0"/>
            <xs:element ref="ccdo:SubjectAddressDetails" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>Адрес хозяйствующего субъекта</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="ccdo:CommunicationDetails" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>Контактный реквизит хозяйствующего субъекта</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="ccdo:FullNameDetails">
                <xs:annotation>
                    <xs:documentation>Фамилия, имя, отчество руководителя</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <!-- M.TR.CDE.00013: Код товара по ТН ВЭД ЕАЭС (Код товара по ТН ВЭД ЕАЭС. Детали) -->
    <xs:element name="CommodityCodeDetails" type="trcdo:CommodityCodeDetailsType">
        <xs:annotation>
            <xs:documentation>информация о коде товара в соответствии с ТН ВЭД ЕАЭС</xs:documentation>
        </xs:annotation>
    </xs:element>
    <!-- M.TR.CDT.01007: Код товара по ТН ВЭД ЕАЭС (Код товара по ТН ВЭД ЕАЭС_ Детали. Тип) -->
    <xs:complexType name="CommodityCodeDetailsType">
        <xs:annotation>
            <xs:documentation>Компоненты, представляющие информацию о коде товара ТН ВЭД ЕАЭС</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element ref="trsdo:PartialCommodityCodeIndicator" minOccurs="0"/>
            <xs:element ref="csdo:CommodityCode">
                <xs:annotation>
                    <xs:documentation>кодовое обозначение группы (класса) товаров в соответствии с ТН ВЭД ЕАЭС</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <!-- M.TR.CDE.00023: Сведения о документе, подтверждающем соответствие (Сведения о документе, подтверждающем соответствие. Детали) -->
    <xs:element name="ComplianceDocDetails" type="trcdo:ComplianceDocDetailsType">
        <xs:annotation>
            <xs:documentation>Информация о документе, представленном в качестве доказательства соответствия обязательным требованиям</xs:documentation>
        </xs:annotation>
    </xs:element>
    <!-- M.TR.CDT.00015: Сведения о документе, подтверждающем соответствие (Сведения о документе, подтверждающем соответствие_ Детали. Тип) -->
    <xs:complexType name="ComplianceDocDetailsType">
        <xs:annotation>
            <xs:documentation>Компоненты, представляющие информацию о документе подтверждающем соответствие</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element ref="csdo:DocName" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Наименование документа, включающее в себя (при необходимости) вид документа, наименование принявшего органа (организации) и собственное наименование документа</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:DocCreationDate" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Дата выдачи документа</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:DocId" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>цифровое или буквенно-цифровое обозначение, присваиваемое документу при его регистрации</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:BusinessEntityName" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Полное наименование хозяйствующего субъекта, выдавшего документ</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="trsdo:ConformityAuthorityId" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>номер органа по оценке соответствия в национальной части единого реестра органов по оценке соответствия</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="trsdo:AccreditationCertificateId" minOccurs="0"/>
            <xs:element ref="trsdo:AccreditationDate" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Дата регистрации документа, подтверждающего аккредитацию органа по оценке соответствия</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:AdditionalInfoText" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Дополнительная информация о документе, подтверждающем соответствие</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <!-- M.TR.CDE.00344: Сведения о документе, обеспечивающем соблюдение требований (Сведения о документе, обеспечивающем соблюдение требований. Детали) -->
    <xs:element name="ComplianceProvidingDocDetails" type="trcdo:ComplianceProvidingDocDetailsType">
        <xs:annotation>
            <xs:documentation>Информация о стандарте или ином документе, в результате применения которого обеспечивается соблюдение установленных требований</xs:documentation>
        </xs:annotation>
    </xs:element>
    <!-- M.TR.CDT.00010: Сведения о документе, обеспечивающем соблюдение требований (Сведения о документе, обеспечивающем соблюдение требований_ Детали. Тип) -->
    <xs:complexType name="ComplianceProvidingDocDetailsType">
        <xs:annotation>
            <xs:documentation>Компоненты, представляющие информацию о стандарте или ином документе, в результате применения которого обеспечивается соблюдение установленных требований</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element ref="trcdo:DocStructuralElementDetails" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element ref="trsdo:StandardListIndicator"/>
            <xs:element ref="csdo:DocName" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Наименование документа</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:DocId" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Цифровое или буквенно-цифровое обозначение, присваиваемое документу при его регистрации</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element ref="csdo:DocCreationDate" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Дата выдачи документа</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <!-- M.TR.CDE.00318: Документ подтверждающий полномочия (Документ подтверждающий полномочия. Детали) -->
    <xs:element name="ConfirmingAuthorityDocDetails" type="trcdo:ConfirmingAuthorityDocDetailsType">
        <xs:annotation>
            <xs:documentation>Информация о документе подтверждающем полномочия</xs:documentation>
        </xs:annotation>
    </xs:element>
    <!-- M.TR.CDT.00318: Сведения о документе подтверждающем полномочия (Сведения о документе подтверждающем полномочия_ Детали. Тип) -->
    <xs:complexType name="ConfirmingAuthorityDocDetailsType">
        <xs:annotation>
            <xs:documentation>Компоненты, представляющие информацию о документе подтверждающем полномочия</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element ref="csdo:DocName" minOccurs="0">
